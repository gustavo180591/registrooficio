{% extends 'base.html.twig' %}

{% block title %}Iniciar Sesión - Registro de Oficios{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .login-container {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="login-container">
    <div class="container-modern" style="max-width: 420px;">
        <div class="card-modern text-center">
            <div class="card-modern-body p-4 p-md-5">
                <!-- Logo -->
                <div class="mb-4">
                    <img src="{{ asset('uploads/images/logo.png') }}" alt="Registro de Oficios" class="img-fluid" style="max-height: 60px;">
                </div>

                <h2 class="fs-3 fw-bold mb-4" style="color: var(--color-primary);">
                    <i class="fas fa-lock me-2"></i>Iniciar Sesión
                </h2>

                <form method="post" class="form-modern text-start">
                    {% if error %}
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <div>{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <label for="username" class="form-label">
                            <i class="fas fa-user me-1 text-muted"></i>Usuario
                        </label>
                        <input type="text" id="username" name="_username" class="form-control form-control-lg" 
                               value="{{ last_username }}" placeholder="Ingrese su usuario" required autofocus>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">
                            <i class="fas fa-key me-1 text-muted"></i>Contraseña
                        </label>
                        <input type="password" id="password" name="_password" class="form-control form-control-lg" 
                               placeholder="Ingrese su contraseña" required>
                    </div>
                    
                    <input type="hidden" name="_target_path" value="/list"/>
                    
                    <div class="d-grid">
                        <button type="submit" class="btn-modern btn-modern-primary btn-lg">
                            <i class="fas fa-sign-in-alt me-2"></i>ENTRAR
                        </button>
                    </div>
                </form>
                
                <!-- Enlace de retorno -->
                <div class="mt-4 pt-3 border-top">
                    <a href="{{ path('app_oficio') }}" class="text-decoration-none text-muted">
                        <i class="fas fa-arrow-left me-1"></i>Volver al inicio
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}