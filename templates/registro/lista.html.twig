{% extends 'base.html.twig' %}

{% block stylesheets %}
{{ parent() }}
<link rel="shortcut icon" href="{{ asset('uploads/images/favicon.ico') }}" type="image/x-icon">

<style>
    /* ============================================
       LISTA.HTML.TWIG - ESTILOS ESPECÍFICOS
       ============================================ */
    
    /* Custom dropdown with integrated search - CRÍTICO para funcionalidad */
    .custom-dropdown-container {
        position: relative;
    }
    
    .custom-dropdown-trigger {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.875rem 1rem;
        border: 2px solid var(--color-gray-200);
        border-radius: var(--radius-md);
        background: var(--color-white);
        cursor: pointer;
        font-size: var(--font-size-base);
        transition: all var(--transition-fast);
        min-height: 48px;
    }
    
    .custom-dropdown-trigger:hover {
        border-color: var(--color-primary);
    }
    
    .custom-dropdown-trigger.active {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }
    
    .custom-dropdown-trigger .selected-text {
        flex-grow: 1;
        color: var(--color-dark);
        text-transform: uppercase;
    }
    
    .custom-dropdown-trigger .selected-text.placeholder {
        color: var(--color-gray-500);
    }
    
    .dropdown-arrow {
        color: var(--color-gray-500);
        transition: transform var(--transition-fast);
        margin-left: 0.5rem;
    }
    
    .custom-dropdown-trigger.active .dropdown-arrow {
        transform: rotate(180deg);
    }
    
    .custom-dropdown-menu {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        background: var(--color-white);
        border: 2px solid var(--color-gray-200);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        z-index: 1050;
        max-height: 400px;
        overflow: hidden;
    }
    
    .dropdown-search {
        padding: 0.75rem;
        border-bottom: 1px solid var(--color-gray-200);
        position: relative;
    }
    
    .dropdown-search .search-input {
        border: 1px solid var(--color-gray-300);
        border-radius: var(--radius-md);
        padding: 0.625rem 2.5rem 0.625rem 0.875rem;
        font-size: var(--font-size-base);
        width: 100%;
        text-transform: uppercase;
    }
    
    .dropdown-search .search-input:focus {
        border-color: var(--color-primary);
        outline: none;
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }
    
    .dropdown-search .search-clear {
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: var(--color-gray-500);
        font-size: 1rem;
        z-index: 10;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all var(--transition-fast);
    }
    
    .dropdown-search .search-clear:hover {
        background-color: var(--color-gray-200);
        color: var(--color-dark);
    }
    
    .dropdown-options {
        max-height: 280px;
        overflow-y: auto;
    }
    
    .dropdown-option {
        padding: 0.75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid var(--color-gray-100);
        font-size: var(--font-size-base);
        text-transform: uppercase;
        transition: background-color var(--transition-fast);
        color: var(--color-dark);
    }
    
    .dropdown-option:hover {
        background-color: var(--color-gray-100);
    }
    
    .dropdown-option.selected {
        background-color: rgba(249, 115, 22, 0.1);
        color: var(--color-primary);
        font-weight: 600;
    }
    
    .dropdown-option.no-results {
        padding: 1rem;
        text-align: center;
        color: var(--color-gray-500);
        font-size: var(--font-size-sm);
        cursor: default;
    }
    
    .search-highlight {
        font-weight: 700;
        color: var(--color-primary);
        background-color: rgba(249, 115, 22, 0.2);
        padding: 0 2px;
        border-radius: 2px;
    }
    
    /* Modal moderno - ajustes específicos */
    .modal-content {
        border: none;
        overflow: hidden;
    }
    
    .modal-header .rounded-circle {
        background: rgba(255, 255, 255, 0.2) !important;
    }
    
    .modal-body .bg-light {
        background-color: var(--color-gray-100) !important;
    }
    
    /* Star rating moderno */
    .star-rating {
        display: flex;
        gap: 0.5rem;
    }
    
    .star-rating .form-check-input {
        display: none;
    }
    
    .star-rating .form-check-label {
        cursor: pointer;
        font-size: 1.5rem;
        transition: transform var(--transition-fast);
        filter: grayscale(100%);
        opacity: 0.5;
    }
    
    .star-rating .form-check-input:checked + .form-check-label,
    .star-rating .form-check-label:hover {
        filter: grayscale(0%);
        opacity: 1;
        transform: scale(1.2);
    }
    
    /* Ajustes responsive específicos */
    @media (max-width: 576px) {
        .custom-dropdown-trigger {
            font-size: var(--font-size-sm);
            padding: 0.75rem;
        }
        
        .dropdown-option {
            font-size: var(--font-size-sm);
            padding: 0.625rem 0.75rem;
        }
        
        .custom-dropdown-menu {
            max-height: 350px;
        }
        
        .dropdown-options {
            max-height: 230px;
        }
        
        .modal-dialog {
            margin: 0.5rem;
        }
    }
    
    /* Scrollbar personalizado para el dropdown */
    .dropdown-options::-webkit-scrollbar {
        width: 8px;
    }
    
    .dropdown-options::-webkit-scrollbar-track {
        background: var(--color-gray-100);
    }
    
    .dropdown-options::-webkit-scrollbar-thumb {
        background: var(--color-gray-300);
        border-radius: 4px;
    }
    
    .dropdown-options::-webkit-scrollbar-thumb:hover {
        background: var(--color-gray-500);
    }
</style>
{% endblock %}
{% block title %}
LISTA DE REGISTROS
{% endblock %}


{% block body %}
<!-- Header compacto con navegación -->
<header class="bg-white shadow-sm py-2">
    <div class="container-modern">
        <div class="d-flex align-items-center justify-content-between">
            <a href="{{ path('app_oficio') }}" class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-2">
                <i class="fas fa-arrow-left"></i>
                <span class="d-none d-sm-inline">VOLVER</span>
            </a>
            <div class="text-center flex-grow-1">
                <img src="{{ asset('uploads/images/logo.png') }}" alt="Logo" class="img-fluid" style="max-height: 50px;">
            </div>
            <a href="{{ path('app_registro') }}" class="btn btn-modern btn-modern-primary btn-sm">
                <i class="fas fa-plus me-1"></i>
                <span class="d-none d-sm-inline">REGISTRARSE</span>
            </a>
        </div>
    </div>
</header>

<!-- Formulario de Búsqueda -->
<section class="py-4">
    <div class="container-modern">
        <div class="card-modern">
            <div class="card-modern-header bg-gradient" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <h2 class="text-center text-white mb-0 fs-4 fw-bold">
                    <i class="fas fa-search me-2"></i>BUSCAR PROFESIONALES
                </h2>
            </div>
            <div class="card-modern-body">
                {{ form_start(form, {'attr': {'class': 'form-modern needs-validation'}}) }}


                <div class="row g-3">
                    <div class="col-lg-6">
                        {{ form_label(form.oficio, 'Oficio', {'label_attr': {'class': 'form-label'}}) }}
                        
                        <!-- Hidden original select for form submission -->
                        {{ form_widget(form.oficio, {
                            'attr': {
                                'style': 'display: none;',
                                'id': 'busqueda_oficio'
                            }
                        }) }}
                        
                        <!-- Custom dropdown with integrated search -->
                        <div class="custom-dropdown-container">
                            <div class="custom-dropdown-trigger" id="oficio-dropdown-trigger">
                                <span id="oficio-selected-text" class="selected-text">-- Seleccionar un oficio --</span>
                                <span class="dropdown-arrow"> <i class="fas fa-chevron-down"></i> </span>
                            </div>
                            
                            <div class="custom-dropdown-menu" id="oficio-dropdown-menu" style="display: none;">
                                <div class="dropdown-search">
                                    <input type="text" 
                                           id="oficio-search" 
                                           class="form-control search-input" 
                                           placeholder="Buscar aquí..."
                                           autocomplete="off">
                                    <span id="search-clear" class="search-clear" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </span>
                                </div>
                                <div class="dropdown-options" id="dropdown-options"></div>
                            </div>
                        </div>
                        
                        <div class="invalid-feedback">
                            {{ form_errors(form.oficio) }}
                        </div>
                    </div>
                    
                    <div class="col-lg-6">
                        {{ form_label(form.delegacion, 'Delegación', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.delegacion, {'attr': {'class': 'form-control', 'placeholder': 'Ingrese delegación'}}) }}
                        <div class="invalid-feedback">
                            {{ form_errors(form.delegacion) }}
                        </div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-center mt-4">
                    <button type="submit" class="btn-modern btn-modern-primary w-100" style="max-width: 300px;">
                        <i class="fas fa-search me-2"></i>BUSCAR
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>

<!-- Resultados de Búsqueda -->
<section class="py-4">
    <div class="container-modern">
        <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3 mb-4">
            <h2 class="heading-responsive fw-bold text-dark mb-0">
                <i class="fas fa-users text-primary me-2"></i>Resultados
            </h2>
            
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-primary fs-6 px-3 py-2 shadow-sm">
                    <i class="fas fa-list me-2"></i>
                    {{ ((currentPage - 1) * limit + 1) }}-{{ min(currentPage * limit, totalItems) }} de {{ totalItems }}
                </span>
            </div>
        </div>
    
        <!-- Cards grid moderno -->
        <div class="row g-4">
            {% for registro in lista %}
                <div class="col-xl-4 col-lg-6 col-md-6">
                    <div class="card-modern h-100 animate-fade-in" style="animation-delay: {{ loop.index * 0.05 }}s;">
                        <div class="card-modern-body d-flex flex-column">
                            <div class="text-center mb-3">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width: 64px; height: 64px;">
                                    <i class="fas fa-user-tie text-primary fs-3"></i>
                                </div>
                                <h3 class="fs-5 fw-bold text-dark mb-1 text-uppercase">
                                    {{ registro.name|upper }}
                                </h3>
                                <span class="badge bg-secondary text-uppercase">
                                    {{ registro.oficio.name|upper }}
                                </span>
                            </div>
                            
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-start gap-2 mb-2 text-responsive">
                                    <i class="fas fa-briefcase text-primary mt-1 flex-shrink-0"></i>
                                    <span class="text-gray-700">{{ registro.description|upper|length > 100 ? registro.description|upper|slice(0, 100) ~ '...' : registro.description|upper }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2 mb-2 text-responsive">
                                    <i class="fas fa-clock text-success flex-shrink-0"></i>
                                    <span class="text-gray-700 text-uppercase">{{ registro.time|upper }}</span>
                                </div>
                                <div class="d-flex align-items-center gap-2 text-responsive">
                                    <i class="fas fa-credit-card text-warning flex-shrink-0"></i>
                                    <span class="text-gray-700 text-uppercase">{{ registro.payment|upper }}</span>
                                </div>
                            </div>
                            
                            <div class="mt-3 pt-3 border-top">
                                <button type="button" class="btn-modern btn-modern-primary w-100" 
                                        data-bs-toggle="modal" data-bs-target="#modal-{{ registro.id }}">
                                    <i class="fas fa-eye me-2"></i>VER DETALLES
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    
        <!-- Paginación moderna -->
        {% if totalPages > 1 %}
        <div class="row mt-5">
            <div class="col-12">
                <nav aria-label="Paginación" class="d-flex flex-column align-items-center gap-3">
                    <ul class="pagination pagination-modern pagination-lg">
                    <!-- First page -->
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': 1}) }}" title="Primera página">
                                <i class="fas fa-angle-double-left"></i>
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Previous page -->
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': currentPage - 1}) }}" title="Página anterior">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Page numbers with smart display -->
                    {% set startPage = max(1, currentPage - 2) %}
                    {% set endPage = min(totalPages, currentPage + 2) %}
                    
                    {% if startPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': 1}) }}">1</a>
                        </li>
                        {% if startPage > 2 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                    {% endif %}
                    
                    {% for page in startPage..endPage %}
                        {% if page == currentPage %}
                            <li class="page-item active">
                                <span class="page-link">{{ page }}</span>
                            </li>
                        {% else %}
                            <li class="page-item">
                                <a class="page-link" href="{{ path('app_lista', {'page': page}) }}">{{ page }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                    
                    {% if endPage < totalPages %}
                        {% if endPage < totalPages - 1 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': totalPages}) }}">{{ totalPages }}</a>
                        </li>
                    {% endif %}
                    
                    <!-- Next page -->
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': currentPage + 1}) }}" title="Página siguiente">
                                Siguiente <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Last page -->
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': totalPages}) }}" title="Última página">
                                <i class="fas fa-angle-double-right"></i>
                            </a>
                        </li>
                    {% endif %}
                    </ul>
                    
                    <!-- Navegación rápida por input -->
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted fs-6">Ir a:</span>
                        <div class="input-group" style="max-width: 140px;">
                            <input type="number" class="form-control form-control-sm text-center" 
                                   id="pageInput" min="1" max="{{ totalPages }}" value="{{ currentPage }}" 
                                   onkeypress="if(event.key === 'Enter') window.location.href='{{ path('app_lista') }}?page=' + this.value">
                            <button class="btn btn-outline-primary btn-sm" type="button"
                                    onclick="window.location.href='{{ path('app_lista') }}?page=' + document.getElementById('pageInput').value">
                                <i class="fas fa-arrow-right"></i>
                            </button>
                        </div>
                        <span class="text-muted fs-6">de {{ totalPages }}</span>
                    </div>
                </nav>
            </div>
        </div>
        {% endif %}
    </div>
</section>

{% for registro in lista %}
    <!-- Modal Moderno -->
    <div class="modal fade" id="modal-{{ registro.id }}" tabindex="-1" aria-labelledby="modalLabel-{{ registro.id }}" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-xl" style="border-radius: var(--radius-lg);">
                <div class="modal-header bg-gradient text-white" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%); border-radius: var(--radius-lg) var(--radius-lg) 0 0;">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="fas fa-user-tie fs-5"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0" id="modalLabel-{{ registro.id }}">
                                {{ registro.name|upper }}
                            </h5>
                            <small class="text-white-50">{{ registro.oficio.name|upper }}</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-2 p-3 bg-light rounded">
                                <i class="fas fa-id-card text-primary fs-5"></i>
                                <div>
                                    <small class="text-muted d-block">NRO. DE REGISTRO</small>
                                    <strong class="fs-5">#{{ registro.id }}</strong>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-user me-1"></i>NOMBRE</small>
                                <strong class="text-uppercase">{{ registro.name|upper }}</strong>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-briefcase me-1"></i>OFICIO</small>
                                <strong class="text-uppercase">{{ registro.oficio.name|upper }}</strong>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <small class="text-muted d-block mb-1"><i class="fas fa-map-marker-alt me-1"></i>DOMICILIO LABORAL</small>
                                <strong class="text-uppercase">{% if registro.workAddress %}{{ registro.workAddress|upper }}{% else %}No especificado{% endif %}</strong>
                            </div>
                        </div>
                        
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <small class="text-muted d-block mb-1"><i class="fas fa-info-circle me-1"></i>DESCRIPCIÓN</small>
                                <p class="mb-0 text-uppercase">{{ registro.description|upper }}</p>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-phone me-1"></i>TELÉFONO</small>
                                <strong class="text-uppercase">{{ registro.phone|upper }}</strong>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-envelope me-1"></i>EMAIL</small>
                                <strong class="text-uppercase">{{ registro.email|upper }}</strong>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-clock me-1"></i>HORARIOS</small>
                                <strong class="text-uppercase">{{ registro.time|upper }}</strong>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <div class="p-3 bg-light rounded h-100">
                                <small class="text-muted d-block mb-1"><i class="fas fa-credit-card me-1"></i>PAGO</small>
                                <strong class="text-uppercase">{{ registro.payment|upper }}</strong>
                            </div>
                        </div>
                        
                        {% if registro.certification %}
                        <div class="col-12">
                            <div class="p-3 bg-success bg-opacity-10 rounded border-start border-success border-4">
                                <small class="text-muted d-block mb-1"><i class="fas fa-certificate me-1 text-success"></i>CERTIFICACIÓN</small>
                                <strong class="text-uppercase d-block">{{ registro.institution|upper }}</strong>
                            </div>
                        </div>
                        {% endif %}
                        
                        {% if registro.images %}
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <small class="text-muted d-block mb-2"><i class="fas fa-image me-1"></i>IMÁGENES</small>
                                <a href="{{ asset('uploads/images/products/' ~ registro.images) }}" target="_blank" class="d-inline-block">
                                    <img src="{{ asset('uploads/images/products/' ~ registro.images) }}" class="img-fluid rounded shadow-sm" style="max-height: 150px;">
                                </a>
                            </div>
                        </div>
                        {% endif %}
                        
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <small class="text-muted d-block mb-2"><i class="fas fa-map-marked-alt me-1"></i>DELEGACIONES</small>
                                <div class="d-flex flex-wrap gap-1">
                                    {% for delegacion in registro.delegacion %}
                                        <span class="badge bg-secondary">{{ delegacion.name }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Sección de Comentarios Colapsable -->
                <div class="collapse border-top" id="comentario-{{ registro.id }}">
                    <div class="p-4 bg-light">
                        <h6 class="fw-bold mb-3 text-primary">
                            <i class="fas fa-pen me-2"></i>DEJAR COMENTARIO
                        </h6>
                        
                        <div class="mb-3">
                            <input type="text" id="name-{{ registro.id }}" class="form-control" placeholder="Ingrese su nombre">
                        </div>
                        
                        <div class="mb-3">
                            <textarea class="form-control" id="comentario-text-{{ registro.id }}" rows="3" placeholder="Escriba su comentario..." maxlength="250"></textarea>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Calificación:</label>
                            <div class="star-rating d-flex gap-2" id="star-rating-{{ registro.id }}">
                                {% for i in 1..5 %}
                                    <div class="form-check form-check-inline m-0">
                                        <input class="form-check-input" type="radio" name="rating-{{ registro.id }}" id="star{{ i }}-{{ registro.id }}" value="{{ i }}">
                                        <label class="form-check-label fs-5" for="star{{ i }}-{{ registro.id }}">⭐</label>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                        
                        <button type="button" class="btn-modern btn-modern-primary" onclick="guardarComentario('{{ registro.id }}')">
                            <i class="fas fa-paper-plane me-2"></i>ENVIAR COMENTARIO
                        </button>
                    </div>
                </div>
                
                <!-- Comentarios existentes -->
                <div class="p-4 bg-light border-top">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-comments me-2 text-primary"></i>COMENTARIOS
                    </h6>
                    
                    <div id="comentario-guardado-{{ registro.id }}"></div>
                    
                    {% if registro.comments|length > 0 %}
                        <div class="d-flex flex-column gap-2">
                            {% for comment in registro.comments|reverse|slice(0, 5) %}
                                <div class="bg-white p-3 rounded shadow-sm">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <strong class="text-primary">{{ comment.name|upper }}</strong>
                                        <span class="badge bg-warning text-dark">{% for i in 1..comment.calification %}⭐{% endfor %}</span>
                                    </div>
                                    <p class="mb-0 text-secondary text-uppercase small">{{ comment.comment|upper }}</p>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-muted text-center mb-0">
                            <i class="fas fa-info-circle me-2"></i>No hay comentarios aún. ¡Sé el primero!
                        </p>
                    {% endif %}
                </div>
                
                <div class="modal-footer bg-white">
                    <div class="d-flex gap-2 w-100">
                        <button type="button" class="btn-modern btn-modern-primary flex-grow-1" data-bs-toggle="collapse" data-bs-target="#comentario-{{ registro.id }}">
                            <i class="fas fa-comment me-2"></i>COMENTAR
                        </button>
                        <button type="button" class="btn-modern btn-modern-outline" data-bs-dismiss="modal">
                            <i class="fas fa-times me-2"></i>CERRAR
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endfor %}
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Custom dropdown with integrated search functionality
    const dropdownTrigger = document.getElementById('oficio-dropdown-trigger');
    const dropdownMenu = document.getElementById('oficio-dropdown-menu');
    const searchInput = document.getElementById('oficio-search');
    const searchClear = document.getElementById('search-clear');
    const optionsContainer = document.getElementById('dropdown-options');
    const selectedText = document.getElementById('oficio-selected-text');
    const originalSelect = document.getElementById('busqueda_oficio');
    
    if (!dropdownTrigger || !originalSelect) return;
    
    // Store all options from original select
    const allOptions = Array.from(originalSelect.options).map(option => ({
        value: option.value,
        text: option.text,
        selected: option.selected
    }));
    
    let isDropdownOpen = false;
    let selectedIndex = -1;
    let filteredOptions = [...allOptions];
    
    // Initialize dropdown with all options
    renderOptions(allOptions);
    
    // Toggle dropdown
    dropdownTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleDropdown();
    });
    
    function toggleDropdown() {
        isDropdownOpen = !isDropdownOpen;
        if (isDropdownOpen) {
            dropdownMenu.style.display = 'block';
            dropdownTrigger.classList.add('active');
            searchInput.focus();
        } else {
            dropdownMenu.style.display = 'none';
            dropdownTrigger.classList.remove('active');
            clearSearch();
        }
    }
    
    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (!dropdownTrigger.contains(e.target) && !dropdownMenu.contains(e.target)) {
            closeDropdown();
        }
    });
    
    function closeDropdown() {
        isDropdownOpen = false;
        dropdownMenu.style.display = 'none';
        dropdownTrigger.classList.remove('active');
        clearSearch();
    }
    
    // Search functionality
    searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase().trim();
        
        if (searchTerm === '') {
            filteredOptions = [...allOptions];
            searchClear.style.display = 'none';
        } else {
            searchClear.style.display = 'block';
            filteredOptions = allOptions.filter(option => {
                if (option.value !== '') { // Skip placeholder
                    return option.text.toLowerCase().includes(searchTerm);
                }
                return false;
            });
        }
        
        renderOptions(filteredOptions);
        selectedIndex = -1;
    });
    
    // Clear search
    searchClear.addEventListener('click', function() {
        clearSearch();
    });
    
    function clearSearch() {
        searchInput.value = '';
        searchClear.style.display = 'none';
        filteredOptions = [...allOptions];
        renderOptions(allOptions);
        selectedIndex = -1;
    }
    
    // Render options
    function renderOptions(options) {
        if (options.length === 0) {
            optionsContainer.innerHTML = '<div class="dropdown-option no-results">No se encontraron resultados</div>';
            return;
        }
        
        const searchTerm = searchInput.value.toLowerCase().trim();
        const html = options.map((option, index) => {
            let displayText = option.text;
            if (searchTerm) {
                displayText = highlightMatch(option.text, searchTerm);
            }
            
            const isSelected = option.value === originalSelect.value;
            return `<div class="dropdown-option ${isSelected ? 'selected' : ''}" data-value="${option.value}" data-index="${index}">
                ${displayText}
            </div>`;
        }).join('');
        
        optionsContainer.innerHTML = html;
        
        // Add click handlers to options
        optionsContainer.querySelectorAll('.dropdown-option:not(.no-results)').forEach(option => {
            option.addEventListener('click', function() {
                selectOption(this.dataset.value);
            });
        });
    }
    
    // Highlight matching text
    function highlightMatch(text, searchTerm) {
        const regex = new RegExp(`(${escapeRegex(searchTerm)})`, 'gi');
        return text.replace(regex, '<span class="search-highlight">$1</span>');
    }
    
    // Escape regex special characters
    function escapeRegex(string) {
        return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    
    // Select option
    function selectOption(value) {
        originalSelect.value = value;
        
        // Update display
        const selectedOption = allOptions.find(opt => opt.value === value);
        if (selectedOption) {
            selectedText.textContent = selectedOption.text;
            selectedText.classList.remove('placeholder');
        } else {
            selectedText.textContent = '-- SELECCIONAR UN OFICIO --';
            selectedText.classList.add('placeholder');
        }
        
        // Re-render options to update selected state
        renderOptions(filteredOptions);
        
        // Close dropdown
        closeDropdown();
        
        // Trigger change event
        const event = new Event('change', { bubbles: true });
        originalSelect.dispatchEvent(event);
    }
    
    // Keyboard navigation
    searchInput.addEventListener('keydown', function(e) {
        const options = optionsContainer.querySelectorAll('.dropdown-option:not(.no-results)');
        
        switch (e.key) {
            case 'ArrowDown':
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, options.length - 1);
                updateKeyboardSelection(options);
                break;
            case 'ArrowUp':
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, -1);
                updateKeyboardSelection(options);
                break;
            case 'Enter':
                e.preventDefault();
                if (selectedIndex >= 0 && options[selectedIndex]) {
                    selectOption(options[selectedIndex].dataset.value);
                }
                break;
            case 'Escape':
                closeDropdown();
                break;
        }
    });
    
    // Update keyboard selection
    function updateKeyboardSelection(options) {
        options.forEach((option, index) => {
            option.classList.toggle('selected', index === selectedIndex);
        });
        
        if (selectedIndex >= 0 && options[selectedIndex]) {
            options[selectedIndex].scrollIntoView({ block: 'nearest' });
        }
    }
    
    // Initialize with current selection
    if (originalSelect.value) {
        const selectedOption = allOptions.find(opt => opt.value === originalSelect.value);
        if (selectedOption) {
            selectedText.textContent = selectedOption.text;
            selectedText.classList.remove('placeholder');
        }
    } else {
        selectedText.textContent = '-- SELECCIONAR UN OFICIO --';
        selectedText.classList.add('placeholder');
    }
});
</script>
{% endblock %}
