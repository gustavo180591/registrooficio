{% extends 'base.html.twig' %}

{% block stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="shortcut icon" href="{{ asset('uploads/images/favicon.ico') }}" type="image/x-icon">
<style>
    body {
        font-family: 'Lato', sans-serif;
        background-color: #f5f5f5;
    }
    .card {
        border: none;
        border-radius: 0.5rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.3);
    }
    .card-body {
        padding: 1.5rem;
    }
    .card-title {
        font-size: 1.5rem;
        font-weight: bold;
        text-transform: uppercase;
    }
    .btn {
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-size: 1.25rem;
        transition: all 0.3s ease;
    }
    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.2);
    }
    .card-text {
        font-size: 1.25rem;
    }
    .btn-primary {
        background-color: #343a40;
        border-color: #343a40;
    }
    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }
    .modal-content {
        max-height: 80vh;
        overflow-y: scroll;
        padding: 2%;
    }
    .modal-header {
        padding: 1.5rem;
        border-bottom: 1px solid #dee2e6;
    }
    .modal-title {
        font-size: 1.5rem;
        font-weight: bold;
        text-transform: uppercase;
    }
    
    /* Enhanced pagination styles */
    .pagination .page-link {
        color: #007bff;
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }
    .pagination .page-link:hover {
        background-color: #e9ecef;
        color: #0056b3;
    }
    .pagination .page-item.active .page-link {
        background-color: #007bff;
        border-color: #007bff;
    }
    .pagination .page-item.disabled .page-link {
        color: #6c757d;
        background-color: #fff;
        border-color: #dee2e6;
    }
    
    /* Badge styling */
    .badge {
        font-size: 0.9em;
        border-radius: 0.5rem;
    }
    
    /* Dropdown styling */
    .dropdown-menu {
        max-height: 300px;
        overflow-y: auto;
    }
    
    /* Input group styling */
    .input-group .form-control:focus {
        border-color: #007bff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }
    
    /* Live search styling */
    .search-container {
        position: relative;
    }
    .search-input {
        font-size: 1.5rem;
        text-transform: uppercase;
        padding-right: 2.5rem;
    }
    .search-clear {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
        font-size: 1.2rem;
        z-index: 10;
    }
    .search-clear:hover {
        color: #495057;
    }
    .search-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #dee2e6;
        border-top: none;
        max-height: 300px;
        overflow-y: auto;
        z-index: 1000;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
    }
    .search-result-item {
        padding: 0.75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f8f9fa;
        font-size: 1.3rem;
        text-transform: uppercase;
        transition: background-color 0.2s ease;
    }
    .search-result-item:hover {
        background-color: #f8f9fa;
    }
    .search-result-item.active {
        background-color: #007bff;
        color: white;
    }
    .search-highlight {
        font-weight: bold;
        color: #007bff;
    }
    .search-result-item.active .search-highlight {
        color: white;
    }
    .no-results {
        padding: 1rem;
        text-align: center;
        color: #6c757d;
        font-size: 1.2rem;
    }
    
    /* Custom dropdown with integrated search styling */
    .custom-dropdown-container {
        position: relative;
    }
    .custom-dropdown-trigger {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 1rem;
        border: 1px solid #ced4da;
        border-radius: 0.375rem;
        background: white;
        cursor: pointer;
        font-size: 1.5rem;
        text-transform: uppercase;
        transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    }
    .custom-dropdown-trigger:hover {
        border-color: #86b7fe;
    }
    .custom-dropdown-trigger:focus,
    .custom-dropdown-trigger.active {
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        outline: 0;
    }
    .selected-text {
        flex-grow: 1;
        color: #495057;
    }
    .selected-text.placeholder {
        color: #6c757d;
    }
    .dropdown-arrow {
        color: #6c757d;
        transition: transform 0.2s ease;
    }
    .custom-dropdown-trigger.active .dropdown-arrow {
        transform: rotate(180deg);
    }
    .custom-dropdown-menu {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: white;
        border: 1px solid #ced4da;
        border-top: none;
        border-radius: 0 0 0.375rem 0.375rem;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
        z-index: 1000;
        max-height: 400px;
        overflow: hidden;
    }
    .dropdown-search {
        padding: 0.75rem;
        border-bottom: 1px solid #e9ecef;
        position: relative;
    }
    .dropdown-search .search-input {
        border: 1px solid #ced4da;
        padding-right: 2.5rem;
    }
    .dropdown-search .search-clear {
        position: absolute;
        right: 1.5rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: #6c757d;
        font-size: 1.2rem;
        z-index: 10;
    }
    .dropdown-search .search-clear:hover {
        color: #495057;
    }
    .dropdown-options {
        max-height: 300px;
        overflow-y: auto;
    }
    .dropdown-option {
        padding: 0.75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid #f8f9fa;
        font-size: 1.3rem;
        text-transform: uppercase;
        transition: background-color 0.2s ease;
    }
    .dropdown-option:hover {
        background-color: #f8f9fa;
    }
    .dropdown-option.selected {
        background-color: #e9ecef;
        font-weight: bold;
    }
    .dropdown-option.no-results {
        padding: 1rem;
        text-align: center;
        color: #6c757d;
        font-size: 1.2rem;
        cursor: default;
    }
    .dropdown-option.no-results:hover {
        background-color: transparent;
    }
    .search-highlight {
        font-weight: bold;
        color: #007bff;
    }
    .dropdown-option.selected .search-highlight {
        color: #0056b3;
    }
    
    /* Responsive adjustments */
    @media (max-width: 768px) {
        .pagination-lg .page-link {
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
        }
        .btn-lg {
            padding: 0.5rem 1rem;
            font-size: 1rem;
        }
        .custom-dropdown-trigger {
            font-size: 1.2rem;
            padding: 0.6rem 0.8rem;
        }
        .dropdown-option {
            font-size: 1.1rem;
            padding: 0.6rem 0.8rem;
        }
        .dropdown-search .search-input {
            font-size: 1.1rem;
        }
    }
</style>
{% endblock %}
{% block title %}
LISTA DE REGISTROS
{% endblock %}


{% block body %}
<div style="position: absolute; top: 1rem; left: 1rem;">
    <div class="d-grid gap-2 col-1 mx-auto my-2">
        <a href="{{ path('app_oficio') }}" class="btn btn-secondary">
            <i class="fas fa-home"></i>
        </a>
    </div>
</div>
<div class="container text-center my-4">
    <img src="{{ asset('uploads/images/logo.png') }}" alt="Logo" class="img-fluid" style="max-width: 75%;">
</div>
<div class="d-flex justify-content-center">


    <div class="card shadow-lg w-100" style="max-width: 90%;">
        <div class="d-flex justify-content-center my-2">
            <a href="{{ path('app_registro') }}" class="btn btn-success d-flex align-items-center justify-content-center" style="height: 50px; width: 300px; border: 0; background-color: #FFA500; hover: background-color: #FF9900;">
                <span class="text-center">REGISTRARSE</span>
            </a>
        </div>
        <div class="card-body p-4">
            <h2 class="text-center mb-4" style="font-size: 2rem; font-weight: bold;">FORMULARIO DE BÚSQUEDA</h2>


            {{ form_start(form, {'attr': {'class': 'needs-validation'}}) }}


            <div class="mb-3 row">
                <div class="col-md-6">
                    {{ form_label(form.oficio, 'OFICIO', {'label_attr': {'class': 'form-label', 'style': 'font-size: 1.5rem;'}}) }}
                    
                    <!-- Hidden original select for form submission -->
                    {{ form_widget(form.oficio, {
                        'attr': {
                            'style': 'display: none;',
                            'id': 'busqueda_oficio'
                        }
                    }) }}
                    
                    <!-- Custom dropdown with integrated search -->
                    <div class="custom-dropdown-container">
                        <div class="custom-dropdown-trigger" id="oficio-dropdown-trigger">
                            <span id="oficio-selected-text" class="selected-text">-- SELECCIONAR UN OFICIO --</span>
                            <span class="dropdown-arrow"> <i class="fas fa-chevron-down"></i> </span>
                        </div>
                        
                        <div class="custom-dropdown-menu" id="oficio-dropdown-menu" style="display: none;">
                            <!-- Search input inside dropdown -->
                            <div class="dropdown-search">
                                <input type="text" 
                                       id="oficio-search" 
                                       class="form-control search-input" 
                                       placeholder="BUSCAR AQUÍ..."
                                       style="font-size: 1.3rem; text-transform: uppercase"
                                       autocomplete="off">
                                <span id="search-clear" class="search-clear" style="display: none;">
                                    <i class="fas fa-times"></i>
                                </span>
                            </div>
                            
                            <!-- Options container -->
                            <div class="dropdown-options" id="dropdown-options">
                                <!-- Options will be populated by JavaScript -->
                            </div>
                        </div>
                    </div>
                    
                    <div class="invalid-feedback" style="font-size: 1.5rem;">
                        {{ form_errors(form.oficio) }}
                    </div>
                </div>
                <div class="col-md-6">
                    {{ form_label(form.delegacion, 'DELEGACIÓN', {'label_attr': {'class': 'form-label', 'style': 'font-size: 1.5rem;'}}) }}
                    {{ form_widget(form.delegacion, {'attr': {'class': 'form-control', 'placeholder': 'INGRESE DELEGACIÓN', 'style': 'font-size: 1.5rem;'}}) }}
                    <div class="invalid-feedback" style="font-size: 1.5rem;">
                        {{ form_errors(form.delegacion) }}
                    </div>
                </div>
            </div>
 
            </div> 
            <div class="d-flex justify-content-end my-2">
                <button type="submit" class="btn btn-primary text-white d-flex align-items-center justify-content-center" style="height: 50px; width: 300px; background-color: #0d6efd; border-color: #0d6efd;">
                    <span class="text-center">BUSCAR</span>
                </button>
            </div>
            {{ form_end(form) }}


        </div>
    </div>
</div>

<div class="container mt-5">
    <h2 class="text-center mb-4" style="font-size: 2rem; font-weight: bold;">LISTA DE REGISTROS</h2>
    
    <!-- Results counter and home button -->
    <div class="row mb-4">
        <div class="col-md-4">
            <a href="{{ path('app_oficio') }}" class="btn btn-secondary btn-lg">
                <i class="fas fa-home me-2"></i>INICIO
            </a>
        </div>
        <div class="col-md-4 text-center">
            <div class="d-flex align-items-center justify-content-center">
                <span class="badge bg-primary fs-6 p-2">
                    <i class="fas fa-list me-2"></i>
                    {{ ((currentPage - 1) * limit + 1) }}-{{ min(currentPage * limit, totalItems) }} de {{ totalItems }} resultados
                </span>
            </div>
        </div>
        <div class="col-md-4 text-end">
            {% if totalPages > 1 %}
                <div class="dropdown">
                    <button class="btn btn-outline-primary btn-lg dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="fas fa-file-alt me-2"></i>Página {{ currentPage }} de {{ totalPages }}
                    </button>
                    <ul class="dropdown-menu">
                        {% for page in 1..totalPages %}
                            <li><a class="dropdown-item {% if page == currentPage %}active{% endif %}" href="{{ path('app_lista', {'page': page}) }}">Página {{ page }}</a></li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}
        </div>
    </div>
    
    <!-- Cards grid -->
    <div class="row">
        {% for registro in lista %}
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm hover-shadow transition-all">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-center mb-3" style="font-size: 1.3rem; font-weight: bold;">
                            {{ registro.name|upper }}
                            <small class="d-block text-muted">({{ registro.oficio.name|upper }})</small>
                        </h5>
                        <div class="flex-grow-1">
                            <p class="card-text mb-2" style="font-size: 1.1rem;">
                                <i class="fas fa-briefcase me-2 text-primary"></i>
                                <strong>DESCRIPCIÓN:</strong> {{ registro.description|upper }}
                            </p>
                            <p class="card-text mb-2" style="font-size: 1.1rem;">
                                <i class="fas fa-clock me-2 text-success"></i>
                                <strong>HORARIO:</strong> {{ registro.time|upper }}
                            </p>
                            <p class="card-text mb-3" style="font-size: 1.1rem;">
                                <i class="fas fa-credit-card me-2 text-warning"></i>
                                <strong>PAGO:</strong> {{ registro.payment|upper }}
                            </p>
                        </div>
                        <div class="mt-auto">
                            <button type="button" class="btn btn-primary w-100 d-flex align-items-center justify-content-center" 
                                    data-bs-toggle="modal" data-bs-target="#modal-{{ registro.id }}" 
                                    style="height: 50px; font-size: 1.1rem;">
                                <i class="fas fa-eye me-2"></i>
                                <span>VER DETALLES</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    
    <!-- Enhanced pagination controls -->
    {% if totalPages > 1 %}
    <div class="row mt-5">
        <div class="col-12">
            <nav aria-label="Page navigation" class="d-flex justify-content-center">
                <ul class="pagination pagination-lg">
                    <!-- First page -->
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': 1}) }}" title="Primera página">
                                <i class="fas fa-angle-double-left"></i>
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Previous page -->
                    {% if currentPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': currentPage - 1}) }}" title="Página anterior">
                                <i class="fas fa-chevron-left"></i> Anterior
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Page numbers with smart display -->
                    {% set startPage = max(1, currentPage - 2) %}
                    {% set endPage = min(totalPages, currentPage + 2) %}
                    
                    {% if startPage > 1 %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': 1}) }}">1</a>
                        </li>
                        {% if startPage > 2 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                    {% endif %}
                    
                    {% for page in startPage..endPage %}
                        {% if page == currentPage %}
                            <li class="page-item active">
                                <span class="page-link">{{ page }}</span>
                            </li>
                        {% else %}
                            <li class="page-item">
                                <a class="page-link" href="{{ path('app_lista', {'page': page}) }}">{{ page }}</a>
                            </li>
                        {% endif %}
                    {% endfor %}
                    
                    {% if endPage < totalPages %}
                        {% if endPage < totalPages - 1 %}
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        {% endif %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': totalPages}) }}">{{ totalPages }}</a>
                        </li>
                    {% endif %}
                    
                    <!-- Next page -->
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': currentPage + 1}) }}" title="Página siguiente">
                                Siguiente <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    {% endif %}
                    
                    <!-- Last page -->
                    {% if currentPage < totalPages %}
                        <li class="page-item">
                            <a class="page-link" href="{{ path('app_lista', {'page': totalPages}) }}" title="Última página">
                                <i class="fas fa-angle-double-right"></i>
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        </div>
    </div>
    
    <!-- Quick navigation -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="d-flex justify-content-center align-items-center gap-3">
                <span class="text-muted">Ir a página:</span>
                <div class="input-group" style="max-width: 200px;">
                    <input type="number" class="form-control" id="pageInput" min="1" max="{{ totalPages }}" value="{{ currentPage }}" 
                           onkeypress="if(event.key === 'Enter') window.location.href='{{ path('app_lista') }}?page=' + this.value">
                    <button class="btn btn-outline-primary" onclick="window.location.href='{{ path('app_lista') }}?page=' + document.getElementById('pageInput').value">
                        <i class="fas fa-arrow-right"></i>
                    </button>
                </div>
                <span class="text-muted">de {{ totalPages }}</span>
            </div>
        </div>
    </div>
    {% endif %}
</div>

{% for registro in lista %}
    <!-- Modal -->
    <style>
        .modal-content {
            max-height: 80vh;
            overflow-y: scroll;
            padding: 2%;
        }
    </style>
    <div class="modal fade" id="modal-{{ registro.id }}" tabindex="-1" aria-labelledby="modalLabel-{{ registro.id }}" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalLabel-{{ registro.id }}" style="font-size: 1.5rem;">DETALLES DE {{ registro.name|upper }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p><strong>NRO. DE REGISTRO:</strong> {{ registro.id }}</p>
                    <p><strong>NOMBRE:</strong> {{ registro.name|upper }}</p>
                    <p><strong>OFICIO:</strong> {{ registro.oficio.name|upper }}</p>
{% if registro.workAddress %}
    <p><strong>DOMICILIO LABORAL:</strong> {{ registro.workAddress|upper }}</p>
{% else %}
    <p><strong>DOMICILIO LABORAL:</strong> NO ESPECIFICADO</p>
{% endif %}

                                <p><strong>DESCRIPCIÓN:</strong> {{ registro.description|upper }}</p>
                                <p><strong>TELÉFONO:</strong> {{ registro.phone|upper }}</p>
                                <p><strong>EMAIL:</strong> {{ registro.email|upper }}</p>
                                <p><strong>HORARIOS DE ATENCIÓN:</strong> {{ registro.time|upper }}</p>
                                <p><strong>MÉTODOS DE PAGO:</strong> {{ registro.payment|upper }}</p>
                                {% if registro.certification %}
                                    <p><strong>CERTIFICACIÓN:</strong> SÍ</p>
                                    <p><strong>INSTITUCIÓN CERTIFICANTE:</strong> {{ registro.institution|upper }}</p>
                                {% else %}
                                    <p><strong>CERTIFICACIÓN:</strong> NO</p>
                                {% endif %}
                                {% if registro.images %}
                                    <p><strong>IMÁGENES:</strong> {% if registro.images %}<a href="{{ asset('uploads/images/products/' ~ registro.images) }}" target="_blank"><img src="{{ asset('uploads/images/products/' ~ registro.images) }}" width="100"></a>{% endif %}</p>
                                {% endif %}
<p><strong>DELEGACIONES DONDE PRESTA SERVICIO:</strong>
				{% for delegacion in registro.delegacion %}
    <li style="display: inline;">{{ delegacion.name }}{% if not loop.last %} - {% endif %} </li>
{% endfor %}</p>
                            </div>
                            <div class="modal-footer">
                                <div class="d-flex justify-content-between gap-2">
                                    <button type="button" class="btn btn-primary d-flex align-items-center justify-content-center flex-grow-1" data-bs-toggle="collapse" data-bs-target="#comentario-{{ registro.id }}" style="height: 50px;"><span class="text-center">NUEVO COMENTARIO</span></button>
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="height: 50px;">CERRAR</button>
                                </div>
                            </div>

                            <!-- Comentarios -->
                            <div class="collapse mt-3" id="comentario-{{ registro.id }}">
                                <h5>NUEVO COMENTARIO</h5>
                                <p class="card-text">
                                    <input type="text" id="name-{{ registro.id }}" placeholder="INGRESE SU NOMBRE" style="font-size: 1.25rem;">
                                </p>
                                <textarea class="form-control" id="comentario-text-{{ registro.id }}" rows="3" placeholder="ESCRIBA SU COMENTARIO..." maxlength="250" style="font-size: 1.25rem;"></textarea>
                                <div class="rating mt-3">
                                    <h6>CALIFICACIÓN:</h6>
                                    <div class="star-rating" id="star-rating-{{ registro.id }}">
                                        {% for i in 1..5 %}
                                            <input type="radio" name="rating-{{ registro.id }}" id="star{{ i }}-{{ registro.id }}" value="{{ i }}" style="font-size: 1.25rem;">
                                            <label for="star{{ i }}-{{ registro.id }}">{{ i }}</label>
                                        {% endfor %}
                                    </div>
                                </div>
                                <button type="button" class="btn btn-success mt-2 d-flex align-items-center justify-content-center" onclick="guardarComentario('{{ registro.id }}')" style="height: 50px; width: 150px; font-size: 1rem;">
                                    <span class="text-center">ENVIAR COMENTARIO</span>
                                </button>
                            </div>

                            <!-- Comentarios guardados -->
                            <div class="mt-3 border p-2 mb-2" id="comentario-guardado-{{ registro.id }}"></div>

                            <!-- Mostrar comentarios existentes -->
                            <div class="mt-3">
                                {% if registro.comments|length > 0 %}
                                    {% for comment in registro.comments|reverse %}
                                        <div class="border p-2 mb-2">
                                            <p><strong>NOMBRE: </strong>{{ comment.name|upper }}
                                            <strong>CALIFICACIÓN: </strong>{% for i in 1..comment.calification %}⭐{% endfor %}
                                            <strong>COMENTARIO: </strong>{{ comment.comment|upper }}</p>
                                        </div>
                                    {% endfor %}
                                {% else %}
                                    <p>NO HAY COMENTARIOS PARA MOSTRAR.</p>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Custom dropdown with integrated search functionality
    const dropdownTrigger = document.getElementById('oficio-dropdown-trigger');
    const dropdownMenu = document.getElementById('oficio-dropdown-menu');
    const searchInput = document.getElementById('oficio-search');
    const searchClear = document.getElementById('search-clear');
    const optionsContainer = document.getElementById('dropdown-options');
    const selectedText = document.getElementById('oficio-selected-text');
    const originalSelect = document.getElementById('busqueda_oficio');
    
    if (!dropdownTrigger || !originalSelect) return;
    
    // Store all options from original select
    const allOptions = Array.from(originalSelect.options).map(option => ({
        value: option.value,
        text: option.text,
        selected: option.selected
    }));
    
    let isDropdownOpen = false;
    let selectedIndex = -1;
    let filteredOptions = [...allOptions];
    
    // Initialize dropdown with all options
    renderOptions(allOptions);
    
    // Toggle dropdown
    dropdownTrigger.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleDropdown();
    });
    
    function toggleDropdown() {
        isDropdownOpen = !isDropdownOpen;
        if (isDropdownOpen) {
            dropdownMenu.style.display = 'block';
            dropdownTrigger.classList.add('active');
            searchInput.focus();
        } else {
            dropdownMenu.style.display = 'none';
            dropdownTrigger.classList.remove('active');
            clearSearch();
        }
    }
    
    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (!dropdownTrigger.contains(e.target) && !dropdownMenu.contains(e.target)) {
            closeDropdown();
        }
    });
    
    function closeDropdown() {
        isDropdownOpen = false;
        dropdownMenu.style.display = 'none';
        dropdownTrigger.classList.remove('active');
        clearSearch();
    }
    
    // Search functionality
    searchInput.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase().trim();
        
        if (searchTerm === '') {
            filteredOptions = [...allOptions];
            searchClear.style.display = 'none';
        } else {
            searchClear.style.display = 'block';
            filteredOptions = allOptions.filter(option => {
                if (option.value !== '') { // Skip placeholder
                    return option.text.toLowerCase().includes(searchTerm);
                }
                return false;
            });
        }
        
        renderOptions(filteredOptions);
        selectedIndex = -1;
    });
    
    // Clear search
    searchClear.addEventListener('click', function() {
        clearSearch();
    });
    
    function clearSearch() {
        searchInput.value = '';
        searchClear.style.display = 'none';
        filteredOptions = [...allOptions];
        renderOptions(allOptions);
        selectedIndex = -1;
    }
    
    // Render options
    function renderOptions(options) {
        if (options.length === 0) {
            optionsContainer.innerHTML = '<div class="dropdown-option no-results">No se encontraron resultados</div>';
            return;
        }
        
        const searchTerm = searchInput.value.toLowerCase().trim();
        const html = options.map((option, index) => {
            let displayText = option.text;
            if (searchTerm) {
                displayText = highlightMatch(option.text, searchTerm);
            }
            
            const isSelected = option.value === originalSelect.value;
            return `<div class="dropdown-option ${isSelected ? 'selected' : ''}" data-value="${option.value}" data-index="${index}">
                ${displayText}
            </div>`;
        }).join('');
        
        optionsContainer.innerHTML = html;
        
        // Add click handlers to options
        optionsContainer.querySelectorAll('.dropdown-option:not(.no-results)').forEach(option => {
            option.addEventListener('click', function() {
                selectOption(this.dataset.value);
            });
        });
    }
    
    // Highlight matching text
    function highlightMatch(text, searchTerm) {
        const regex = new RegExp(`(${escapeRegex(searchTerm)})`, 'gi');
        return text.replace(regex, '<span class="search-highlight">$1</span>');
    }
    
    // Escape regex special characters
    function escapeRegex(string) {
        return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }
    
    // Select option
    function selectOption(value) {
        originalSelect.value = value;
        
        // Update display
        const selectedOption = allOptions.find(opt => opt.value === value);
        if (selectedOption) {
            selectedText.textContent = selectedOption.text;
            selectedText.classList.remove('placeholder');
        } else {
            selectedText.textContent = '-- SELECCIONAR UN OFICIO --';
            selectedText.classList.add('placeholder');
        }
        
        // Re-render options to update selected state
        renderOptions(filteredOptions);
        
        // Close dropdown
        closeDropdown();
        
        // Trigger change event
        const event = new Event('change', { bubbles: true });
        originalSelect.dispatchEvent(event);
    }
    
    // Keyboard navigation
    searchInput.addEventListener('keydown', function(e) {
        const options = optionsContainer.querySelectorAll('.dropdown-option:not(.no-results)');
        
        switch (e.key) {
            case 'ArrowDown':
                e.preventDefault();
                selectedIndex = Math.min(selectedIndex + 1, options.length - 1);
                updateKeyboardSelection(options);
                break;
            case 'ArrowUp':
                e.preventDefault();
                selectedIndex = Math.max(selectedIndex - 1, -1);
                updateKeyboardSelection(options);
                break;
            case 'Enter':
                e.preventDefault();
                if (selectedIndex >= 0 && options[selectedIndex]) {
                    selectOption(options[selectedIndex].dataset.value);
                }
                break;
            case 'Escape':
                closeDropdown();
                break;
        }
    });
    
    // Update keyboard selection
    function updateKeyboardSelection(options) {
        options.forEach((option, index) => {
            option.classList.toggle('selected', index === selectedIndex);
        });
        
        if (selectedIndex >= 0 && options[selectedIndex]) {
            options[selectedIndex].scrollIntoView({ block: 'nearest' });
        }
    }
    
    // Initialize with current selection
    if (originalSelect.value) {
        const selectedOption = allOptions.find(opt => opt.value === originalSelect.value);
        if (selectedOption) {
            selectedText.textContent = selectedOption.text;
            selectedText.classList.remove('placeholder');
        }
    } else {
        selectedText.textContent = '-- SELECCIONAR UN OFICIO --';
        selectedText.classList.add('placeholder');
    }
});
</script>
{% endblock %}
