{% extends 'base.html.twig' %}

{% block title %}Registrarse - Registro de Oficios{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="shortcut icon" href="{{ asset('uploads/images/favicon.ico') }}" type="image/x-icon">
<style>
    /* Estilos específicos para el formulario de registro */
    .delegaciones-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.75rem;
        max-height: 300px;
        overflow-y: auto;
        padding: 1rem;
        background: var(--color-gray-100);
        border-radius: var(--radius-md);
    }
    
    .delegaciones-grid .form-check {
        margin: 0;
        padding: 0.5rem;
        background: white;
        border-radius: var(--radius-sm);
        transition: all var(--transition-fast);
    }
    
    .delegaciones-grid .form-check:hover {
        background: rgba(249, 115, 22, 0.1);
    }
    
    .delegaciones-grid .form-check-input {
        width: 1.25rem;
        height: 1.25rem;
        margin-right: 0.5rem;
        cursor: pointer;
    }
    
    .delegaciones-grid .form-check-label {
        cursor: pointer;
        font-size: var(--font-size-sm);
        text-transform: uppercase;
    }
    
    .btn-select-all {
        font-size: var(--font-size-sm);
        padding: 0.5rem 1rem;
    }
    
    @media (max-width: 576px) {
        .delegaciones-grid {
            grid-template-columns: 1fr;
            max-height: 250px;
        }
    }
</style>
{% endblock %}

{% block body %}
<!-- Header -->
<header class="bg-white shadow-sm py-3 mb-4">
    <div class="container-modern">
        <div class="d-flex align-items-center justify-content-between">
            <a href="{{ path('app_oficio') }}" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>VOLVER
            </a>
            <div class="text-center flex-grow-1">
                <img src="{{ asset('uploads/images/logo.png') }}" alt="Logo" class="img-fluid" style="max-height: 40px;">
            </div>
            <div style="width: 80px;"></div><!-- Spacer for balance -->
        </div>
    </div>
</header>

<!-- Formulario de Registro -->
<section class="py-4">
    <div class="container-modern" style="max-width: 800px;">
        <div class="card-modern">
            <div class="card-modern-header bg-gradient text-white text-center" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <h2 class="fs-4 fw-bold mb-0">
                    <i class="fas fa-user-plus me-2"></i>FORMULARIO DE REGISTRO
                </h2>
                <p class="mb-0 mt-1 text-white-50 small">Complete sus datos para registrarse en el sistema</p>
            </div>
            
            <div class="card-modern-body">
                {{ form_start(form, {'attr': {'class': 'form-modern needs-validation', 'novalidate': 'novalidate'}}) }}

                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_label(form.name, 'Nombre y Apellido', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ingrese su nombre completo'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.name) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.email, 'Correo Electrónico', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'correo@ejemplo.com'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.email) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.date, 'Fecha de Nacimiento', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.date, {'attr': {'class': 'form-control date-input', 'placeholder': 'DD-MM-AAAA'}}) }}
                        <div class="form-text text-muted small">Ejemplo: 01-01-2000</div>
                        <div class="invalid-feedback">{{ form_errors(form.date) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.dni, 'DNI', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.dni, {'attr': {'class': 'form-control', 'placeholder': 'Número de DNI'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.dni) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.phone, 'Teléfono', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.phone, {'attr': {'class': 'form-control', 'placeholder': 'Teléfono de contacto'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.phone) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.address, 'Dirección', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.address, {'attr': {'class': 'form-control', 'placeholder': 'Dirección personal'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.address) }}</div>
                    </div>
                    
                    <div class="col-12">
                        {{ form_label(form.oficio, 'Oficio', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.oficio, {'attr': {'class': 'form-select', 'style': 'text-transform: uppercase'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.oficio) }}</div>
                        
                        <button type="button" class="btn btn-link btn-select-all mt-2 p-0 text-decoration-none" data-bs-toggle="modal" data-bs-target="#recomendacionModal">
                            <i class="fas fa-plus-circle me-1"></i>¿Tu oficio no está en la lista? Solicitar nuevo oficio
                        </button>
                    </div>
                    
                    <div class="col-12">
                        {{ form_label(form.description, 'Descripción de su actividad', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Describa su actividad laboral', 'rows': '3'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.description) }}</div>
                    </div>
                </div>

                <!-- Delegaciones -->
                <div class="mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        {{ form_label(form.delegacion, 'Delegaciones donde presta servicio', {'label_attr': {'class': 'form-label mb-0'}}) }}
                        <button type="button" class="btn btn-outline-primary btn-sm btn-select-all" id="select-all-delegaciones">
                            <i class="fas fa-check-double me-1"></i>Seleccionar todas
                        </button>
                    </div>
                    
                    <div class="delegaciones-grid" id="delegacion-container">
                        {% for child in form.delegacion %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input delegacion-checkbox'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                    <div class="invalid-feedback">{{ form_errors(form.delegacion) }}</div>
                </div>
                <!-- Datos de trabajo -->
                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        {{ form_label(form.workAddress, 'Dirección de trabajo (opcional)', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.workAddress, {'attr': {'class': 'form-control', 'placeholder': 'Dirección donde trabaja'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.workAddress) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.payment, 'Métodos de pago aceptados', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.payment, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Efectivo, Transferencia'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.payment) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.time, 'Horario de atención', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.time, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Lunes a Viernes 9-17hs'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.time) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.recomendation, 'Referencias laborales', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.recomendation, {'attr': {'class': 'form-control', 'placeholder': 'Referencias de trabajos anteriores'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.recomendation) }}</div>
                    </div>
                </div>
                
                <!-- Certificación -->
                <div class="mt-4">
                    <label class="form-label">¿Posee certificación profesional?</label>
                    <div class="d-flex gap-4 align-items-center">
                        {% for child in form.certification %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                    <div class="invalid-feedback">{{ form_errors(form.certification) }}</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.institution, 'Institución certificante (si aplica)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.institution, {'attr': {'class': 'form-control', 'placeholder': 'Nombre de la institución'}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.institution) }}</div>
                </div>
                
                <!-- Imagen -->
                <div class="mb-4">
                    {{ form_label(form.imageFile, 'Imagen o Logo (opcional)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                    <div class="form-text text-muted small">Formatos aceptados: JPG, PNG. Máximo 2MB.</div>
                    <div class="invalid-feedback">{{ form_errors(form.imageFile) }}</div>
                </div>
                
                <!-- Botón de envío -->
                <div class="d-grid">
                    <button type="submit" class="btn-modern btn-modern-primary btn-lg">
                        <i class="fas fa-paper-plane me-2"></i>REGISTRARSE
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>

<!-- Modal de Solicitud de Oficio -->
<div class="modal fade" id="recomendacionModal" tabindex="-1" aria-labelledby="recomendacionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-xl">
            <div class="modal-header bg-gradient text-white" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <h5 class="modal-title fw-bold" id="recomendacionModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Solicitar Nuevo Oficio
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="recomendacionForm" method="POST" action="{{ path('app_crear_recomendacion') }}">
                    <div class="mb-3">
                        <label for="recomendacionText" class="form-label">Descripción del oficio solicitado</label>
                        <textarea class="form-control" id="recomendacionText" name="recomendacionText" rows="3" 
                                  placeholder="Describa el oficio que desea agregar a la lista..." required></textarea>
                        <div class="form-text text-muted">La solicitud será revisada antes de su aprobación.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modern btn-modern-outline" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>CANCELAR
                </button>
                <button type="submit" form="recomendacionForm" class="btn-modern btn-modern-primary">
                    <i class="fas fa-paper-plane me-2"></i>ENVIAR SOLICITUD
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Formato automático de fecha DD-MM-AAAA
    document.addEventListener('DOMContentLoaded', function() {
        const dateInputs = document.querySelectorAll('.date-input');
        
        dateInputs.forEach(function(input) {
            input.addEventListener('input', function(e) {
                let value = this.value.replace(/[^0-9]/g, '');
                
                if (value.length > 2 && value.length <= 4) {
                    value = value.replace(/(\d{2})(\d+)/, '$1-$2');
                } else if (value.length > 4) {
                    value = value.replace(/(\d{2})(\d{2})(\d+)/, '$1-$2-$3');
                }
                
                this.value = value;
            });
        });
        
        // Seleccionar todas las delegaciones
        const selectAllBtn = document.getElementById('select-all-delegaciones');
        if (selectAllBtn) {
            selectAllBtn.addEventListener('click', function() {
                const checkboxes = document.querySelectorAll('.delegacion-checkbox');
                const allChecked = Array.from(checkboxes).every(cb => cb.checked);
                
                checkboxes.forEach(function(checkbox) {
                    checkbox.checked = !allChecked;
                });
                
                // Actualizar texto del botón
                this.innerHTML = allChecked 
                    ? '<i class="fas fa-check-double me-1"></i>Seleccionar todas'
                    : '<i class="fas fa-times me-1"></i>Desmarcar todas';
            });
        }
    });
</script>
{% endblock %}
