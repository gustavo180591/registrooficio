{% extends 'base.html.twig' %}

{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}Registrarse - Registro de Oficios{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="shortcut icon" href="{{ asset('uploads/images/favicon.ico') }}" type="image/x-icon">
<style>
    /* Estilos específicos para el formulario de registro */
    .delegaciones-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.75rem;
        max-height: 300px;
        overflow-y: auto;
        padding: 1rem;
        background: var(--color-gray-100);
        border-radius: var(--radius-md);
    }
    
    .delegaciones-grid .form-check {
        margin: 0;
        padding: 0.5rem;
        background: white;
        border-radius: var(--radius-sm);
        transition: all var(--transition-fast);
    }
    
    .delegaciones-grid .form-check:hover {
        background: rgba(249, 115, 22, 0.1);
    }
    
    .delegaciones-grid .form-check-input {
        width: 1.25rem;
        height: 1.25rem;
        margin-right: 0.5rem;
        cursor: pointer;
    }
    
    .delegaciones-grid .form-check-label {
        cursor: pointer;
        font-size: var(--font-size-sm);
        text-transform: uppercase;
    }
    
    .btn-select-all {
        font-size: var(--font-size-sm);
        padding: 0.5rem 1rem;
    }
    
    @media (max-width: 576px) {
        .delegaciones-grid {
            grid-template-columns: 1fr;
            max-height: 250px;
        }
    }
    
    /* Custom dropdown with integrated search - para selector de oficios */
    .custom-dropdown-container {
        position: relative;
    }
    
    .custom-dropdown-trigger {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.875rem 1rem;
        border: 2px solid var(--color-gray-200);
        border-radius: var(--radius-md);
        background: var(--color-white);
        cursor: pointer;
        font-size: var(--font-size-base);
        transition: all var(--transition-fast);
        min-height: 48px;
    }
    
    .custom-dropdown-trigger:hover {
        border-color: var(--color-primary);
    }
    
    .custom-dropdown-trigger.active {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }
    
    .custom-dropdown-trigger .selected-text {
        flex-grow: 1;
        color: var(--color-dark);
        text-transform: uppercase;
    }
    
    .custom-dropdown-trigger .selected-text.placeholder {
        color: var(--color-gray-500);
    }
    
    .dropdown-arrow {
        color: var(--color-gray-500);
        transition: transform var(--transition-fast);
        margin-left: 0.5rem;
    }
    
    .custom-dropdown-trigger.active .dropdown-arrow {
        transform: rotate(180deg);
    }
    
    .custom-dropdown-menu {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        background: var(--color-white);
        border: 2px solid var(--color-gray-200);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-lg);
        z-index: 1050;
        max-height: 400px;
        overflow: hidden;
    }
    
    .dropdown-search {
        padding: 0.75rem;
        border-bottom: 1px solid var(--color-gray-200);
        position: relative;
    }
    
    .dropdown-search .search-input {
        border: 1px solid var(--color-gray-300);
        border-radius: var(--radius-md);
        padding: 0.625rem 2.5rem 0.625rem 0.875rem;
        font-size: var(--font-size-base);
        width: 100%;
        text-transform: uppercase;
    }
    
    .dropdown-search .search-input:focus {
        border-color: var(--color-primary);
        outline: none;
        box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.1);
    }
    
    .dropdown-search .search-clear {
        position: absolute;
        right: 1.25rem;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: var(--color-gray-500);
        font-size: 1rem;
        z-index: 10;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all var(--transition-fast);
    }
    
    .dropdown-search .search-clear:hover {
        background-color: var(--color-gray-200);
        color: var(--color-dark);
    }
    
    .dropdown-options {
        max-height: 280px;
        overflow-y: auto;
    }
    
    .dropdown-option {
        padding: 0.75rem 1rem;
        cursor: pointer;
        border-bottom: 1px solid var(--color-gray-100);
        font-size: var(--font-size-base);
        text-transform: uppercase;
        transition: background-color var(--transition-fast);
        color: var(--color-dark);
    }
    
    .dropdown-option:hover {
        background-color: var(--color-gray-100);
    }
    
    .dropdown-option.selected {
        background-color: rgba(249, 115, 22, 0.1);
        color: var(--color-primary);
        font-weight: 600;
    }
    
    .dropdown-option.no-results {
        padding: 1rem;
        text-align: center;
        color: var(--color-gray-500);
        font-size: var(--font-size-sm);
        cursor: default;
    }
    
    .search-highlight {
        font-weight: 700;
        color: var(--color-primary);
        background-color: rgba(249, 115, 22, 0.2);
        padding: 0 2px;
        border-radius: 2px;
    }
    
    /* Scrollbar personalizado */
    .dropdown-options::-webkit-scrollbar {
        width: 8px;
    }
    
    .dropdown-options::-webkit-scrollbar-track {
        background: var(--color-gray-100);
    }
    
    .dropdown-options::-webkit-scrollbar-thumb {
        background: var(--color-gray-300);
        border-radius: 4px;
    }
    
    .dropdown-options::-webkit-scrollbar-thumb:hover {
        background: var(--color-gray-500);
    }
    
    @media (max-width: 576px) {
        .custom-dropdown-trigger {
            font-size: var(--font-size-sm);
            padding: 0.75rem;
        }
        
        .dropdown-option {
            font-size: var(--font-size-sm);
            padding: 0.625rem 0.75rem;
        }
        
        .custom-dropdown-menu {
            max-height: 350px;
        }
        
        .dropdown-options {
            max-height: 230px;
        }
    }
</style>
{% endblock %}

{% block body %}
<!-- Header -->
<header class="bg-white shadow-sm py-3 mb-4">
    <div class="container-modern">
        <div class="d-flex align-items-center justify-content-between">
            <a href="{{ path('app_oficio') }}" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>VOLVER
            </a>
            <div class="text-center flex-grow-1">
                <img src="{{ asset('uploads/images/logo.png') }}" alt="Logo" class="img-fluid" style="max-height: 40px;">
            </div>
            <div style="width: 80px;"></div><!-- Spacer for balance -->
        </div>
    </div>
</header>

<!-- Formulario de Registro -->
<section class="py-4">
    <div class="container-modern" style="max-width: 800px;">
        <div class="card-modern">
            <div class="card-modern-header bg-gradient text-white text-center" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <h2 class="fs-4 fw-bold mb-0">
                    <i class="fas fa-user-plus me-2"></i>FORMULARIO DE REGISTRO
                </h2>
                <p class="mb-0 mt-1 text-white-50 small">Complete sus datos para registrarse en el sistema</p>
            </div>
            
            <div class="card-modern-body">
                {{ form_start(form, {'attr': {'class': 'form-modern needs-validation', 'novalidate': 'novalidate'}}) }}
                
                {# Mostrar errores globales del formulario #}
                {% if form.vars.errors|length > 0 %}
                    <div class="alert alert-danger mb-3">
                        <i class="fas fa-exclamation-circle me-2"></i>Por favor, complete todos los campos obligatorios.
                    </div>
                {% endif %}

                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_label(form.name, 'Nombre y Apellido', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Ingrese su nombre completo'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.name) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.email, 'Correo Electrónico', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'correo@ejemplo.com'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.email) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.date, 'Fecha de Nacimiento', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.date, {'attr': {'class': 'form-control date-input', 'placeholder': 'DD-MM-AAAA'}}) }}
                        <div class="form-text text-muted small">Ejemplo: 01-01-2000</div>
                        <div class="invalid-feedback">{{ form_errors(form.date) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.dni, 'DNI', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.dni, {'attr': {'class': 'form-control', 'placeholder': 'Número de DNI'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.dni) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.phone, 'Teléfono', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.phone, {'attr': {'class': 'form-control', 'placeholder': 'Teléfono de contacto'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.phone) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.address, 'Dirección', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.address, {'attr': {'class': 'form-control', 'placeholder': 'Dirección personal'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.address) }}</div>
                    </div>
                    
                    <div class="col-12">
                        {{ form_label(form.oficio, 'Oficio', {'label_attr': {'class': 'form-label'}}) }}
                        
                        <!-- Select original oculto para el formulario -->
                        {{ form_widget(form.oficio, {'attr': {'style': 'display: none;'}}) }}
                        
                        <!-- Custom dropdown con búsqueda integrada -->
                        <div class="custom-dropdown-container">
                            <div class="custom-dropdown-trigger" id="oficio-dropdown-trigger">
                                <span id="oficio-selected-text" class="selected-text placeholder">-- Seleccionar un oficio --</span>
                                <span class="dropdown-arrow"><i class="fas fa-chevron-down"></i></span>
                            </div>
                            
                            <div class="custom-dropdown-menu" id="oficio-dropdown-menu" style="display: none;">
                                <div class="dropdown-search">
                                    <input type="text" 
                                           id="oficio-search" 
                                           class="form-control search-input" 
                                           placeholder="Buscar oficio..."
                                           autocomplete="off">
                                    <span id="search-clear" class="search-clear" style="display: none;">
                                        <i class="fas fa-times"></i>
                                    </span>
                                </div>
                                <div class="dropdown-options" id="dropdown-options"></div>
                            </div>
                        </div>
                        
                        <div class="invalid-feedback">{{ form_errors(form.oficio) }}</div>
                        
                        <button type="button" class="btn btn-link btn-select-all mt-2 p-0 text-decoration-none" data-bs-toggle="modal" data-bs-target="#recomendacionModal">
                            <i class="fas fa-plus-circle me-1"></i>¿Tu oficio no está en la lista? Solicitar nuevo oficio
                        </button>
                    </div>
                    
                    <div class="col-12">
                        {{ form_label(form.description, 'Descripción de su actividad', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Describa su actividad laboral', 'rows': '3'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.description) }}</div>
                    </div>
                </div>

                <!-- Delegaciones -->
                <div class="mt-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        {{ form_label(form.delegacion, 'Delegaciones donde presta servicio', {'label_attr': {'class': 'form-label mb-0'}}) }}
                        <button type="button" class="btn btn-outline-primary btn-sm btn-select-all" id="select-all-delegaciones">
                            <i class="fas fa-check-double me-1"></i>Seleccionar todas
                        </button>
                    </div>
                    
                    <div class="delegaciones-grid" id="delegacion-container">
                        {% for child in form.delegacion %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input delegacion-checkbox'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                    <div class="invalid-feedback">{{ form_errors(form.delegacion) }}</div>
                </div>
                <!-- Datos de trabajo -->
                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        {{ form_label(form.workAddress, 'Dirección de trabajo (opcional)', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.workAddress, {'attr': {'class': 'form-control', 'placeholder': 'Dirección donde trabaja'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.workAddress) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.payment, 'Métodos de pago aceptados', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.payment, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Efectivo, Transferencia'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.payment) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.time, 'Horario de atención', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.time, {'attr': {'class': 'form-control', 'placeholder': 'Ej: Lunes a Viernes 9-17hs'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.time) }}</div>
                    </div>
                    
                    <div class="col-md-6">
                        {{ form_label(form.recomendation, 'Referencias laborales', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.recomendation, {'attr': {'class': 'form-control', 'placeholder': 'Referencias de trabajos anteriores'}}) }}
                        <div class="invalid-feedback">{{ form_errors(form.recomendation) }}</div>
                    </div>
                </div>
                
                <!-- Certificación -->
                <div class="mt-4">
                    <label class="form-label">¿Posee certificación profesional?</label>
                    <div class="d-flex gap-4 align-items-center">
                        {% for child in form.certification %}
                            <div class="form-check">
                                {{ form_widget(child, {'attr': {'class': 'form-check-input'}}) }}
                                {{ form_label(child, null, {'label_attr': {'class': 'form-check-label'}}) }}
                            </div>
                        {% endfor %}
                    </div>
                    <div class="invalid-feedback">{{ form_errors(form.certification) }}</div>
                </div>
                
                <div class="mb-3">
                    {{ form_label(form.institution, 'Institución certificante (si aplica)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.institution, {'attr': {'class': 'form-control', 'placeholder': 'Nombre de la institución'}}) }}
                    <div class="invalid-feedback">{{ form_errors(form.institution) }}</div>
                </div>
                
                <!-- Imagen -->
                <div class="mb-4">
                    {{ form_label(form.imageFile, 'Imagen o Logo (opcional)', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                    <div class="form-text text-muted small">Formatos aceptados: JPG, PNG. Máximo 2MB.</div>
                    <div class="invalid-feedback">{{ form_errors(form.imageFile) }}</div>
                </div>
                
                <!-- Botón de envío -->
                <div class="d-grid">
                    <button type="submit" class="btn-modern btn-modern-primary btn-lg">
                        <i class="fas fa-paper-plane me-2"></i>REGISTRARSE
                    </button>
                </div>
                
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</section>

<!-- Modal de Solicitud de Oficio -->
<div class="modal fade" id="recomendacionModal" tabindex="-1" aria-labelledby="recomendacionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-xl">
            <div class="modal-header bg-gradient text-white" style="background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);">
                <h5 class="modal-title fw-bold" id="recomendacionModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Solicitar Nuevo Oficio
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="recomendacionForm" method="POST" action="{{ path('app_crear_recomendacion') }}">
                    <div class="mb-3">
                        <label for="recomendacionText" class="form-label">Descripción del oficio solicitado</label>
                        <textarea class="form-control" id="recomendacionText" name="recomendacionText" rows="3" 
                                  placeholder="Describa el oficio que desea agregar a la lista..." required></textarea>
                        <div class="form-text text-muted">La solicitud será revisada antes de su aprobación.</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modern btn-modern-outline" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>CANCELAR
                </button>
                <button type="submit" form="recomendacionForm" class="btn-modern btn-modern-primary">
                    <i class="fas fa-paper-plane me-2"></i>ENVIAR SOLICITUD
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Formato automático de fecha DD-MM-AAAA
    document.addEventListener('DOMContentLoaded', function() {
        const dateInputs = document.querySelectorAll('.date-input');
        
        dateInputs.forEach(function(input) {
            input.addEventListener('input', function(e) {
                let value = this.value.replace(/[^0-9]/g, '');
                
                if (value.length > 2 && value.length <= 4) {
                    value = value.replace(/(\d{2})(\d+)/, '$1-$2');
                } else if (value.length > 4) {
                    value = value.replace(/(\d{2})(\d{2})(\d+)/, '$1-$2-$3');
                }
                
                this.value = value;
            });
        });
        
        // Seleccionar todas las delegaciones
        const selectAllBtn = document.getElementById('select-all-delegaciones');
        if (selectAllBtn) {
            selectAllBtn.addEventListener('click', function() {
                const checkboxes = document.querySelectorAll('.delegacion-checkbox');
                const allChecked = Array.from(checkboxes).every(cb => cb.checked);
                
                checkboxes.forEach(function(checkbox) {
                    checkbox.checked = !allChecked;
                });
                
                // Actualizar texto del botón
                this.innerHTML = allChecked 
                    ? '<i class="fas fa-check-double me-1"></i>Seleccionar todas'
                    : '<i class="fas fa-times me-1"></i>Desmarcar todas';
            });
        }
        
        // Dropdown personalizado con búsqueda integrada para oficios
        const dropdownTrigger = document.getElementById('oficio-dropdown-trigger');
        const dropdownMenu = document.getElementById('oficio-dropdown-menu');
        const searchInput = document.getElementById('oficio-search');
        const searchClear = document.getElementById('search-clear');
        const optionsContainer = document.getElementById('dropdown-options');
        const selectedText = document.getElementById('oficio-selected-text');
        const originalSelect = document.getElementById('registro_oficio');
        
        if (dropdownTrigger && originalSelect) {
            // Almacenar todas las opciones del select original
            const allOptions = Array.from(originalSelect.options).map(option => ({
                value: option.value,
                text: option.text,
                selected: option.selected
            }));
            
            let isDropdownOpen = false;
            let filteredOptions = [...allOptions];
            
            // Inicializar dropdown con todas las opciones
            renderOptions(allOptions);
            
            // Toggle dropdown
            dropdownTrigger.addEventListener('click', function(e) {
                e.stopPropagation();
                toggleDropdown();
            });
            
            function toggleDropdown() {
                isDropdownOpen = !isDropdownOpen;
                if (isDropdownOpen) {
                    dropdownMenu.style.display = 'block';
                    dropdownTrigger.classList.add('active');
                    searchInput.focus();
                } else {
                    dropdownMenu.style.display = 'none';
                    dropdownTrigger.classList.remove('active');
                    clearSearch();
                }
            }
            
            // Cerrar dropdown al hacer click fuera
            document.addEventListener('click', function(e) {
                if (!dropdownTrigger.contains(e.target) && !dropdownMenu.contains(e.target)) {
                    closeDropdown();
                }
            });
            
            function closeDropdown() {
                isDropdownOpen = false;
                dropdownMenu.style.display = 'none';
                dropdownTrigger.classList.remove('active');
                clearSearch();
            }
            
            // Funcionalidad de búsqueda
            searchInput.addEventListener('input', function(e) {
                const searchTerm = e.target.value.toLowerCase().trim();
                
                if (searchTerm === '') {
                    filteredOptions = [...allOptions];
                    searchClear.style.display = 'none';
                } else {
                    searchClear.style.display = 'block';
                    filteredOptions = allOptions.filter(option => {
                        if (option.value !== '') {
                            return option.text.toLowerCase().includes(searchTerm);
                        }
                        return false;
                    });
                }
                
                renderOptions(filteredOptions);
            });
            
            // Limpiar búsqueda
            searchClear.addEventListener('click', function() {
                clearSearch();
                searchInput.focus();
            });
            
            function clearSearch() {
                searchInput.value = '';
                searchClear.style.display = 'none';
                filteredOptions = [...allOptions];
                renderOptions(allOptions);
            }
            
            // Renderizar opciones
            function renderOptions(options) {
                if (options.length === 0) {
                    optionsContainer.innerHTML = '<div class="dropdown-option no-results">No se encontraron resultados</div>';
                    return;
                }
                
                const searchTerm = searchInput.value.toLowerCase().trim();
                const html = options.map((option) => {
                    let displayText = option.text;
                    if (searchTerm) {
                        displayText = highlightMatch(option.text, searchTerm);
                    }
                    
                    const isSelected = option.value === originalSelect.value;
                    return '<div class="dropdown-option ' + (isSelected ? 'selected' : '') + '" data-value="' + option.value + '">' + displayText + '</div>';
                }).join('');
                
                optionsContainer.innerHTML = html;
                
                // Agregar event listeners a las opciones
                optionsContainer.querySelectorAll('.dropdown-option:not(.no-results)').forEach(option => {
                    option.addEventListener('click', function() {
                        selectOption(this.dataset.value);
                    });
                });
            }
            
            // Resaltar texto coincidente
            function highlightMatch(text, searchTerm) {
                const regex = new RegExp('(' + escapeRegex(searchTerm) + ')', 'gi');
                return text.replace(regex, '<span class="search-highlight">$1</span>');
            }
            
            // Escapar caracteres especiales de regex
            function escapeRegex(string) {
                return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            }
            
            // Seleccionar opción
            function selectOption(value) {
                originalSelect.value = value;
                
                // Actualizar display
                const selectedOption = allOptions.find(opt => opt.value === value);
                if (selectedOption && selectedOption.value !== '') {
                    selectedText.textContent = selectedOption.text;
                    selectedText.classList.remove('placeholder');
                } else {
                    selectedText.textContent = '-- Seleccionar un oficio --';
                    selectedText.classList.add('placeholder');
                }
                
                // Re-renderizar para actualizar estado seleccionado
                renderOptions(filteredOptions);
                
                // Cerrar dropdown
                closeDropdown();
                
                // Disparar evento change
                const event = new Event('change', { bubbles: true });
                originalSelect.dispatchEvent(event);
            }
        }
    });
</script>
{% endblock %}
